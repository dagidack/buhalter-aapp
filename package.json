{
  "name": "buhalter",
  "version": "0.1.0",
  "description": "RM fin bookkeeping desktop app",
  "author": "RM fin",
  "private": true,
  "main": "electron/main.js",
  "build": {
    "appId": "com.rm-fin.desktop",
    "productName": "RM fin",
    "asar": true,
    "asarUnpack": [
      "electron/next-server.js",
      "node_modules/next",
      "node_modules/@next",
      ".next"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "next.config.ts",
      "next-env.d.ts",
      "package.json",
      "src/**/*",
      "tsconfig.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next/standalone"
      },
      {
        "from": ".env.local",
        "to": "env/.env.local"
      },
      {
        "from": "My Accounting App IAM.json",
        "to": "secrets/My Accounting App IAM.json"
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next/standalone/dist && next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "electron .",
    "electron:build": "rm -rf .next/standalone/dist && npm run build && rm -rf .next/standalone/dist && electron-builder --mac && node scripts/prepare-electron-bundle.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
